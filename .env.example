# Copy this file to .env and fill in real values. .env is gitignored.
# These variables drive `make up` (local development stack).

# --- App ---------------------------------------------------------------------

# Host port the app is exposed on (container always listens on 3000)
APP_PORT=3000

# 32+ byte random string. Generate with: openssl rand -hex 32
# REQUIRED — the default in docker-compose.yml is a marker, not a secret.
SESSION_SECRET=

# First-boot password for the seeded `root` user.
# After first login, change it in the admin UI.
INITIAL_ROOT_PASSWORD=

# --- Optional ----------------------------------------------------------------

# Override these only if the defaults clash with something else on your machine.
# DB_PORT=5432
# REDIS_PORT=6379

# Timezone for the app container
TZ=UTC

# Log every SQL statement (noisy — only useful when debugging the DB layer)
DEBUG_SQL=false

# --- Outbound proxy (optional) -----------------------------------------------
# Uncomment when calling upstream LLM APIs through a forward proxy.
# HTTPS_PROXY=http://localhost:7890
