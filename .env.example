# Copy this file to .env and fill in real values. .env is gitignored.
# These variables drive `make up` (local development stack).

# --- App ---------------------------------------------------------------------

# Host port the app is exposed on (container always listens on 3000)
APP_PORT=3000

# 32+ byte random string. Generate with: openssl rand -hex 32
# REQUIRED — the default in docker-compose.yml is a marker, not a secret.
SESSION_SECRET=

# First-boot password for the seeded `root` user.
# After first login, change it in the admin UI.
INITIAL_ROOT_PASSWORD=

# --- Optional ----------------------------------------------------------------

# Override these only if the defaults clash with something else on your machine.
# DB_PORT=5432
# REDIS_PORT=6379

# Timezone for the app container
TZ=UTC

# Log every SQL statement (noisy — only useful when debugging the DB layer)
DEBUG_SQL=false

# --- Outbound proxy (optional) -----------------------------------------------
# Uncomment when calling upstream LLM APIs through a forward proxy.
# HTTPS_PROXY=http://localhost:7890

# --- Payments (P0) -----------------------------------------------------------
# All payment gateways are OFF by default. Enable each one per deployment by
# (a) setting the env vars below AND (b) toggling the matching option in
# admin UI (PaymentEnabled, StripeEnabled, EpayEnabled, CryptoAdaptersEnabled).
# See docs/SANDBOX_TOPUP_TESTING.md for end-to-end local testing instructions.

# --- Stripe ---
# Get keys from Stripe dashboard (sandbox: Developers → API keys with
# sandbox selected). Never commit real keys.
STRIPE_API_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd

# --- E-Pay (彩虹易支付协议 — 支付宝/微信/QQ) ---
# From your 易支付 merchant dashboard. EPAY_URL ends in /submit.php.
EPAY_ID=
EPAY_KEY=
EPAY_URL=
EPAY_DEFAULT_METHOD=alipay

# --- Crypto: NOWPayments (default crypto adapter) ---
# Sign up at nowpayments.io. Sandbox: api-sandbox.nowpayments.io.
# To enable, ALSO set CryptoAdaptersEnabled=nowpayments in admin option.
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_BASE_CURRENCY=usd
NOWPAYMENTS_SANDBOX=false
